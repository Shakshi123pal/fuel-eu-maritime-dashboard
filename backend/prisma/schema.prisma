generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Route {
  id               Int     @id @default(autoincrement())
  route_id         String  @unique
  year             Int
  vessel_type      String
  fuel_type        String
  ghg_intensity    Float
  fuel_consumption Float
  distance         Float
  total_emissions  Float
  is_baseline      Boolean @default(false)
}

model ShipCompliance {
  id          Int     @id @default(autoincrement())
  ship_id     String
  year        Int
  cb_gco2eq   Float
  createdAt   DateTime @default(now())
}

model BankEntry {
  id          Int     @id @default(autoincrement())
  ship_id     String
  year        Int
  amount_gco2eq Float
  createdAt   DateTime @default(now())
}

model Pool {
  id         Int     @id @default(autoincrement())
  year       Int
  createdAt  DateTime @default(now())
  members    PoolMember[]
}

model PoolMember {
  id        Int     @id @default(autoincrement())
  pool      Pool    @relation(fields: [poolId], references: [id])
  poolId    Int
  ship_id   String
  cb_before Float
  cb_after  Float
}
